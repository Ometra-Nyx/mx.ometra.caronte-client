# ============================================================================
# Caronte Authentication Server Configuration (REQUIRED)
# ============================================================================
CARONTE_URL=https://caronte.example.com
CARONTE_APP_CN=your_app_cn_here
CARONTE_APP_SECRET=your_app_secret_here
CARONTE_APPLICATION_GROUP_ID=
CARONTE_APPLICATION_GROUP_SECRET=

# ============================================================================
# JWT Token Verification (Optional)
# ============================================================================
CARONTE_ISSUER_ID=your_issuer_id_here
CARONTE_ENFORCE_ISSUER=true

# ============================================================================
# Authentication Features (Optional)
# ============================================================================
CARONTE_2FA=false
CARONTE_ALLOW_HTTP_REQUESTS=false
CARONTE_TLS_VERIFY=true

# ============================================================================
# Route Configuration (Optional)
# ============================================================================
CARONTE_ROUTES_PREFIX=
CARONTE_SUCCESS_URL=/
CARONTE_LOGIN_URL=/login

# ============================================================================
# User Management (Optional)
# ============================================================================
CARONTE_UPDATE_LOCAL_USER=false

# ============================================================================
# View & UI Configuration (Optional)
# ============================================================================
CARONTE_USE_INERTIA=false

# ============================================================================
# Database Configuration (Optional)
# ============================================================================
CARONTE_TABLE_PREFIX=
