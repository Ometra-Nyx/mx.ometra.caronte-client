{
  "name": "ometra/caronte-sdk",
  "description": "Caronte SDK",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Gabriel Ruelas",
      "email": "gruelas@gruelas.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "equidna/bee-hive": "^3.0",
    "equidna/laravel-toolkit": ">=1.0.0",
    "lcobucci/jwt": "^5.3",
    "lcobucci/clock": "^3.2",
    "illuminate/support": "^12.0",
    "laravel/framework": "^12.0",
    "laravel/prompts": "^0.3.7",
    "inertiajs/inertia-laravel": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Ometra\\Caronte\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "scripts": {
    "post-autoload-dump": [],
    "test": "phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ometra\\Caronte\\Providers\\CaronteServiceProvider"
      ]
    }
  }
}
